---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About — Good Dog Rocky">
  <section class="about-hero">
    <img src={`${base}images/dogs-running.jpg`} alt="Happy dogs" class="about-hero-img" />
  </section>

  <h1>About Good Dog Rocky</h1>

  <section class="about-content">
    <p>
      Good Dog Rocky is a locally owned and operated pet shop located in Ashburn, Virginia.
      We're passionate about pets and committed to providing the Brambleton community and
      surrounding areas with high-quality natural pet food, supplies, and grooming services.
    </p>

    <p>
      We believe that pets are family, and they deserve the same quality of care and nutrition
      that we'd want for ourselves. That's why we hand-pick every product on our shelves,
      focusing on natural, wholesome brands that prioritize your pet's health and well-being.
    </p>

    <h2>Our Mission</h2>
    <p>
      To be the trusted neighborhood destination where pet owners can find premium products,
      expert advice, and exceptional grooming services — all in a welcoming, community-focused
      environment.
    </p>

    <h2>Why Choose Us?</h2>
    <ul>
      <li><strong>Locally owned</strong> — We're part of your community and invested in your pet's happiness.</li>
      <li><strong>Knowledgeable staff</strong> — Our team genuinely loves animals and stays up to date on pet nutrition and care.</li>
      <li><strong>Curated selection</strong> — We carry only products we believe in, with a focus on natural and high-quality brands.</li>
      <li><strong>Convenient services</strong> — Professional grooming and self-service dog wash all under one roof.</li>
      <li><strong>Welcoming atmosphere</strong> — Pets (and their humans) are always welcome to stop in and say hi!</li>
    </ul>
  </section>
</BaseLayout>

<style>
  .about-hero {
    margin-bottom: 2rem;
    border-radius: 12px;
    overflow: hidden;
  }

  .about-hero-img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    display: block;
  }

  .about-content p {
    color: var(--text-light);
    margin-bottom: 1rem;
    max-width: 800px;
  }

  .about-content h2 {
    margin-top: 2rem;
  }

  .about-content ul {
    margin: 1rem 0 1rem 1.5rem;
    color: var(--text-light);
    max-width: 800px;
  }

  .about-content li {
    margin-bottom: 0.5rem;
  }
</style>
